{
	"name": "boilerplate-worker",
	"main": "src/index.ts",
	"compatibility_date": "2025-03-07",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true,
		"head_sampling_rate": 1,
	},
	"kv_namespaces": [
		{
			"binding": "CONFIG_KV",
			"id": "YOUR_KV_NAMESPACE_ID",
		},
	],
	"services": [
		// Example service binding:
		// {
		// 	"binding": "TRADE_SERVICE",
		// 	"service": "trade-worker",
		// },
	],
}
